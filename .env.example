# ── Clio ──────────────────────────────────────────────────────────────────────
# Webhook signing secret (from Clio → Settings → Integrations → Webhooks)
CLIO_WEBHOOK_SECRET=

# Clio OAuth access token (from Clio Developer App)
CLIO_ACCESS_TOKEN=

# Full name as it appears in Clio under responsible attorney
RESPONSIBLE_ATTORNEY_NAME=Nick Noe

# Minutes to wait after matter.created before syncing (default 60)
DELAY_MINUTES=60

# ── Box ───────────────────────────────────────────────────────────────────────
# Option A: Long-lived credentials via OAuth (preferred — auto-refreshes)
BOX_CLIENT_ID=
BOX_CLIENT_SECRET=
BOX_REFRESH_TOKEN=

# Option B: Short-lived token (expires in ~60 min — fallback only)
BOX_ACCESS_TOKEN=bb13851eb561b4641d59e96ee7f337f44224892bf76b299a475860eed40f2de3

# ── Slack ─────────────────────────────────────────────────────────────────────
SLACK_BOT_TOKEN=
SLACK_DM_CHANNEL=UQCGA53CJ

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── Misc ──────────────────────────────────────────────────────────────────────
PORT=3000
LOG_LEVEL=info
